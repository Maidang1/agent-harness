{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JIAJIA",
  "version": "0.0.0",
  "identifier": "com.bookagent.desktop",
  "build": {
    "beforeDevCommand": "corepack pnpm dev:desktop:web",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "corepack pnpm build:desktop",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "JIAJIA",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 640,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 16, "y": 28 },
        "transparent": true,
        "windowEffects": {
          "effects": ["sidebar"],
          "state": "active",
          "radius": 12
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM2QUNFOUZDQTM4NUVBOTAKUldTUTZvV2ovT21zeGxOcGR0ZktDa0VpSEJNbUNzK0dac25KRkUvQU02Mk5naXVybFJFY25KUk8K",
      "endpoints": [
        "https://github.com/Maidang1/agent-harness/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
