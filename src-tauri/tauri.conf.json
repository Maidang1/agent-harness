{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Book Agent",
  "version": "0.0.0",
  "identifier": "com.bookagent.desktop",
  "build": {
    "beforeDevCommand": "corepack pnpm dev:desktop:web",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "corepack pnpm build:desktop",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Book Agent",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 640,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 16, "y": 22 },
        "transparent": true,
        "windowEffects": {
          "effects": ["sidebar"],
          "state": "active",
          "radius": 12
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
